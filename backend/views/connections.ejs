<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connections / SnapTalk</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet">
  <style>
    /* Matching your profile.ejs scrollbar style */
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f5f9;
    }

    ::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 3px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #94a3b8;
    }

    /* Tab indicator styling to match profile behavior */
    .tab-btn {
      position: relative;
      font-weight: 600;
      color: #64748b;
      transition: all 0.2s;
    }

    .tab-btn.active {
      color: #0f172a;
    }

    .tab-btn.active::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 40px;
      height: 4px;
      background-color: #1d4ed8;
      border-radius: 2px;
    }
  </style>
</head>

<body class="bg-slate-100 text-gray-800 font-sans pb-20 lg:pb-0">
  <div class="container mx-auto flex">

    <!-- Left Sidebar (Width fix: Removed lg:w-1/4 to match profile.ejs) -->
    <div id="sidebar-partial-call" class="hidden lg:block">
      <%- include('partials/sidebar') %>
    </div>

    <!-- Main Content (Exact width matching profile.ejs) -->
    <main class="w-full lg:w-1/2 min-h-screen bg-white border-l border-r border-slate-200">

      <!-- Sticky Header -->
      <div class="sticky top-0 z-10 bg-slate-100/80 backdrop-blur-md px-4 py-2 border-b border-slate-200">
        <div class="flex items-center space-x-4">
          <a href="/profile/<%= profileUser.username %>" class="p-2 rounded-full hover:bg-slate-200">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
          </a>
          <div>
            <h2 class="text-xl font-bold text-gray-900 capitalize">Connections</h2>
            <p class="text-xs text-gray-500"><%= profileUser.username %></p>
          </div>
        </div>
      </div>

      <!-- Connection Tabs -->
      <div id="tab-controls" class="flex justify-around border-b border-slate-200 bg-white">
        <button onclick="switchTab('followers')" id="btn-followers" class="tab-btn active w-full text-center py-4">Followers</button>
        <button onclick="switchTab('following')" id="btn-following" class="tab-btn w-full text-center py-4">Following</button>
      </div>

      <!-- Content Area -->
      <div class="divide-y divide-slate-100">
        <!-- Followers Section -->
        <div id="section-followers" class="tab-pane">
          <% if(followerList.length) {%>
          <% followerList.forEach((list) => {%>
          <!-- Example User Row -->
          <div class="flex items-center justify-between p-4 hover:bg-slate-50 transition-colors">
            <div class="flex items-center gap-3">
              <img src=<%= followerUserProfile?.profilePic?.url? followerUserProfile?.profilePic?.url:`https://placehold.co/128x128/1d4ed8/ffffff?text=${list.name[0].toUpperCase()}` %> class="z-10 rounded-full h-12 w-12 border border-slate-200" alt="Avatar">
              <div>
                <h4 class="font-bold text-sm text-gray-900 capitalize"><%= list.name %></h4>
                <p class="text-xs text-gray-500">@<%= list.username %></p>
              </div>
            </div>
            <!-- Professional Button Style -->
            <% if(!list.isItMe) {%>
            <button data-profileOwnerUserId="<%= list._id %>" class="followBtnFromConnections px-3 sm:px-5 py-1.5 sm:py-2 text-xs sm:text-sm font-semibold rounded-full transition-all duration-300 hover:scale-105 active:scale-95 flex items-center gap-1.5 border whitespace-nowrap hover:shadow-sm <%= list.isFollowing ? 'bg-[#f8fafc] text-[#334155] border-[#dbe1e8]' : 'bg-white text-[#0f172a] border-[#dbe1e8] hover:bg-[#f8fafc]' %>">
              <% if(list.isFollowing){ %>
              <i class="ri-check-line text-base"></i>
              <% } else { %>
              <i class="ri-add-line text-base"></i>
              <% } %>
              <%= list.isFollowing ? "Following" : "Follow" %>
            </button>
            <% } %>
          </div>
          <% })  %>
          <% } else{%>
          <span class="flex items-center justify-center mt-[50px] text-[20px] text-gray-500 text-center px-4">
            you will see all people who follows you here.
          </span>
          <% } %>
        </div>
      </div>
      <!-- Following Section (Hidden by default) -->
      <div id="section-following" class="tab-pane hidden">
        <% if(followingList.length) {%>
        <% followingList.forEach((list) => { %>
        <div class="flex items-center justify-between p-4 hover:bg-slate-50 transition-colors">
          <a href="/profile/<%= list.username %>?from=connections&connectionOwner=<%= profileUser.username%>" class="flex items-center gap-3">
            <img src=<%= list?.profilepic? list?.profilepic:`https://placehold.co/128x128/1d4ed8/ffffff?text=${list.name[0].toUpperCase()}` %> class="z-10 rounded-full h-12 w-12 border border-slate-200" alt="Avatar">
            <div>
              <h4 class="font-bold text-sm text-gray-900 capitalize"><%= list.name %></h4>
              <p class="text-xs text-gray-500">@<%= list.username %></p>
            </div>
          </a>
          <% if(!list.isItMe){%>
          <button data-profileOwnerUserId="<%= list._id %>" class="followBtnFromConnections px-3 sm:px-5 py-1.5 sm:py-2 text-xs sm:text-sm font-semibold rounded-full transition-all duration-300 hover:scale-105 active:scale-95 flex items-center gap-1.5 border whitespace-nowrap hover:shadow-sm <%= list.isFollowing ? 'bg-[#f8fafc] text-[#334155] border-[#dbe1e8]' : 'bg-white text-[#0f172a] border-[#dbe1e8] hover:bg-[#f8fafc]' %>">
            <% if(list.isFollowing){ %>
            <i class="ri-check-line text-base"></i>
            <% } else { %>
            <i class="ri-add-line text-base"></i>
            <% } %>
            <%= list.isFollowing ? "Following" : "Follow" %>
          </button>
          <%} %>
        </div>
        <% }) %>
        <% }else{ %>
        <span class="flex items-center justify-center mt-[50px] text-[20px] text-gray-500 text-center px-4">
          You're not following anyone yet.
        </span>
        <% } %>
      </div>
  </div>
  </main>

  <!-- Right Column (Width fix: Removed wrapper and lg:w-1/4 to exactly match profile.ejs logic) -->
  <%- include('partials/rightColumn') %>

  </div>

  <!-- Mobile Nav Placeholder -->
  <div class="lg:hidden fixed bottom-0 w-full h-16 bg-white border-t border-slate-200 z-50 flex items-center justify-around">
    <i class="ri-home-line text-xl"></i>
    <i class="ri-search-line text-xl"></i>
    <i class="ri-notification-line text-xl"></i>
    <i class="ri-user-fill text-xl text-blue-600"></i>
  </div>

  <script src="/js/followSystem.js"></script>
  <script>
    function switchTab(type) {
      const followersBtn = document.getElementById('btn-followers');
      const followingBtn = document.getElementById('btn-following');
      const followersSection = document.getElementById('section-followers');
      const followingSection = document.getElementById('section-following');

      if (type === 'followers') {
        followersBtn.classList.add('active');
        followingBtn.classList.remove('active');
        followersSection.classList.remove('hidden');
        followingSection.classList.add('hidden');
      } else {
        followingBtn.classList.add('active');
        followersBtn.classList.remove('active');
        followingSection.classList.remove('hidden');
        followersSection.classList.add('hidden');
      }
    }
  </script>
</body>

</html>