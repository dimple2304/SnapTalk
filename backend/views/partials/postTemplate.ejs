<style>
  /* Heart pop animation */
  @keyframes pop {
    0% {
      transform: scale(1);
    }

    50% {
      transform: scale(1.4);
    }

    100% {
      transform: scale(1);
    }
  }

  /* Burst dots flying outward */
  @keyframes burst {
    0% {
      transform: scale(0.2);
      opacity: 1;
    }

    80% {
      opacity: 1;
    }

    100% {
      transform: scale(1) translate(var(--x), var(--y));
      opacity: 0;
    }
  }

  .heart-pop {
    animation: pop 0.4s ease-in-out;
  }

  .burst-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    background-color: #ec4899;
    border-radius: 50%;
    transform-origin: center;
    animation: burst 0.6s ease-out forwards;
  }
</style>
<link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet">
<% 
// If a single post is passed in, wrap it as an array for unified handling
let postArray = [];

if (typeof post !== "undefined") {
  postArray = [post];
} else if (Array.isArray(posts) && posts.length > 0) {
  postArray = posts;
}
%>

<% if (postArray.length > 0) { %>
<% postArray.forEach(function (element) { %>
<div class="bg-white p-3 sm:p-4 md:p-6 rounded-2xl shadow-sm overflow-hidden">
  <div class="flex items-start gap-3 sm:gap-4 w-full min-w-0">
    <button class="userProfileBtn shrink-0" data-userprofile="/profile/<%= element.user?.username %>?from=feed">
      <img src="<%= element.profile?.profilepic?.url || `https://placehold.co/128x128/1d4ed8/ffffff?text=${user.name[0].toUpperCase()}` %>" alt="Avatar" class="rounded-full h-10 w-10 sm:h-12 sm:w-12 object-cover shrink-0">
    </button>
    <div class="w-full min-w-0">
      <!-- Header -->
      <div class="flex justify-between items-start gap-3 w-full">
        <div class="flex items-center gap-1 sm:gap-2 flex-wrap min-w-0">
          <button class="userProfileBtn" data-userprofile="/profile/<%= element.user?.username %>">
            <span class="font-bold text-gray-900 text-sm sm:text-base break-words">
              <%= element.user?.name %>
            </span>
            <span class="text-gray-400 text-xs sm:text-sm ml-1 break-all">
              @<%= element.user?.username %>
            </span>
          </button>
          <span class="text-gray-400 text-sm">•</span>
          <span class="post-time text-gray-400 text-xs sm:text-sm" data-time="<%= element.createdAt %>"></span>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <% if(!element.isOwnPost){ %>
          <button data-postOwnerUserId="<%= element.user._id %>" class="followBtn px-3 sm:px-5 py-1.5 sm:py-2 text-xs sm:text-sm font-semibold rounded-full transition-all duration-300 hover:scale-105 active:scale-95 flex items-center gap-1.5 border whitespace-nowrap hover:shadow-sm <%= element.isFollowing ? 'bg-[#f8fafc] text-[#334155] border-[#dbe1e8]' : 'bg-white text-[#0f172a] border-[#dbe1e8] hover:bg-[#f8fafc]' %>">
            <% if(element.isFollowing){ %>
            <i class="ri-check-line text-base"></i>
            <% } else { %>
            <i class="ri-add-line text-base"></i>
            <% } %>
            <%= element.isFollowing ? "Following" : "Follow" %>
          </button>
          <span id="follow-err" class="follow-error error text-red-500 text-xs mt-1 block"></span>
          <% } %>
          <% if(element.isOwnPost){ %>
          <div class="postMenu relative ml-auto">
            <button class="text-gray-400 hover:text-gray-600 transition-colors shrink-0">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z">
                </path>
              </svg>
            </button>
            <div id="menu-<%= element._id %>" data-postId="<%= element._id %>" class="postDeleteBtn hidden absolute right-0 mt-1 w-32 bg-white border border-slate-100 rounded-md shadow-lg z-10">
              <button type="submit" class="w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-red-50 flex items-center gap-2 rounded-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Delete
              </button>
            </div>
          </div>
          <% } %>
        </div>
      </div>
      <button class="postPageBtn" data-postpageurl="/post/<%= element._id %>?from=<%= source %><% if(source === 'profile'){ %>&username=<%= profileUsername %><% } %>">
        <!-- Post Content -->
        <p class="mt-1 text-gray-700 text-left text-sm sm:text-base break-words leading-relaxed">
          <%= element.thought %>
        </p>
        <!-- Media -->
        <div class="postdynamicimg">
          <% if (element.media?.url) { %>
          <img src="<%= element.media.url %>" class="w-full max-h-[220px] sm:max-h-[350px] mt-4 object-cover rounded-xl" alt="Post image">
          <% } %>
        </div>
      </button>
      <!-- Post Actions -->
      <div class="flex justify-between sm:justify-start items-center mt-4 sm:mt-5 gap-4 sm:gap-8 text-gray-500 flex-wrap">
        <!-- Like Button -->
        <div class="like-button relative flex items-center space-x-2 
              <%= element.likes?.some(el => el.user?.toString() === user?._id?.toString()) ? 'text-pink-500' : 'hover:text-pink-500' %> 
              cursor-pointer" data-userIdOfFeed="<%= user?._id %>" data-postId="<%= element._id %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
          </svg>
          <div class="likes-count text-black">
            <%= element.likes?.length > 0 ? element.likes.length : "" %>
          </div>
        </div>
        <!-- Comment -->
        <button class="postPageBtn" data-postpageurl="/post/<%= element._id %>?from=<%= source %><% if(source === 'profile'){ %>&username=<%= profileUsername %><% } %>">
          <div class="comment-post flex items-center space-x-2 hover:text-blue-500 cursor-pointer" data-commentPostId="<%= element._id %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 5v8a2 2 0 01-2 2h-5l-5 4v-4H4a2 2 0 01-2-2V5a2 2 0 012-2h12a2 2 0 012 2zM7 8H5v2h2V8zm2 0h2v2H9V8zm6 0h-2v2h2V8z" clip-rule="evenodd" />
            </svg>
            <span class="comment-count">
              <%= element.comments?.length>0 ? element.comments.length : "" %>
            </span>
          </div>
        </button>
        <!-- Share -->
        <div class="flex items-center space-x-2 hover:text-green-500 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M15 8a3 3 0 10-2.977-2.63l-4.94 2.47a3 3 0 100 4.319l4.94 2.47a3 3 0 10.895-1.789l-4.94-2.47a3.027 3.027 0 000-.74l4.94-2.47C13.456 7.68 14.19 8 15 8z" />
          </svg>
          <span>15</span>
        </div>
      </div>
    </div>
  </div>
</div>
<% }) %>
<% } else { %>
<p class="text-gray-500 text-center mt-10">No posts yet.</p>
<% } %>


<script src="/js/postTimeFormatter.js"></script>
<script src="/js/deletePost.js"></script>
<script>
  document.querySelectorAll(".userProfileBtn").forEach(btn => {
    btn.addEventListener("click", () => {
      const url = btn.dataset.userprofile;

      if (!url) return;

      window.location.href = url;
    });
  });

  // const postPageBtn = document.querySelectorAll(".postPageBtn");
  document.addEventListener("click", function(e) {
    const btn = e.target.closest(".postPageBtn");
    if (!btn) return;
    const url = btn.dataset.postpageurl;
    if (window.location.pathname !== url) {
      window.location.href = url;
    }
  })

  document.querySelectorAll(".like-button").forEach(button => {
    button.addEventListener("click", function() {
      const svg = this.querySelector("svg");

      const isLiked = this.classList.toggle("text-pink-500");
      this.classList.toggle("text-gray-500", !isLiked);

      if (!isLiked) return;

      svg.classList.add("heart-pop");
      setTimeout(() => svg.classList.remove("heart-pop"), 400);

      for (let i = 0; i < 6; i++) {
        const circle = document.createElement("span");
        circle.classList.add("burst-circle");

        const angle = (Math.PI * 2 * i) / 6;
        const distance = 35;
        circle.style.setProperty("--x", `${Math.cos(angle) * distance}px`);
        circle.style.setProperty("--y", `${Math.sin(angle) * distance}px`);

        this.appendChild(circle);
        setTimeout(() => circle.remove(), 1200);
      }
    });
  });
</script>