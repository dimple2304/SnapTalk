<aside class="hidden lg:block w-1/3 p-4" data-current-user-id="<%= loggedInUser._id %>">
  <div class="sticky top-4 space-y-6">

    <!-- <div id="right-story-partial-call">
      <%#- include("stories") %>
    </div> -->

    <div class="bg-white rounded-2xl p-5 shadow-sm">
      <h3 class="font-bold text-xl mb-4">Suggestions</h3>
      <div class="space-y-2">
        <% if(allUsers && allUsers.length>0){ %>
        <% allUsers.forEach(au => { %>
        <div class="flex items-center justify-between p-2 rounded-lg hover:bg-slate-100 transition-colors duration-200">
          <a href="/profile/<%= au?.username %>">
            <div class="flex items-center">
              <img src="<%= au.pp?au.pp: `https://placehold.co/40x40/1d4ed8/ffffff?text=${au.name?.charAt(0).toUpperCase()}` %>" alt="Avatar" class="rounded-full h-10 w-10">
              <div class="ml-3">
                <p class="font-bold text-gray-800"><%= au.name %></p>
                <p class="text-sm text-gray-400">@<%= au.username %></p>
              </div>
            </div>
          </a>
          <button data-profileOwnerUserId="<%= au._id %>" class="followBtnFromSidebar px-3 sm:px-5 py-1.5 sm:py-2 text-xs sm:text-sm font-semibold rounded-full transition-all duration-300 hover:scale-105 active:scale-95 flex items-center gap-1.5 border whitespace-nowrap hover:shadow-sm <%= au.isFollowing ? 'bg-[#f8fafc] text-[#334155] border-[#dbe1e8]' : 'bg-white text-[#0f172a] border-[#dbe1e8] hover:bg-[#f8fafc]' %>">
            <% if(au.isFollowing){ %>
            <i class="ri-check-line text-base"></i>
            <% } else { %>
            <i class="ri-add-line text-base"></i>
            <% } %>
            <%= au.isFollowing ? "Following" : "Follow" %>
          </button>
        </div>
        <% }); %>
        <% } else{%>
        <span class="flex items-center justify-center mt-[50px] text-[20px] text-gray-500 text-center px-4">
          You'll see more users here soon. Until then, enjoy SnapTalk!
        </span>
        <% } %>
      </div>

