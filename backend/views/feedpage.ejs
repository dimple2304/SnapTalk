<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home / SnapTalk</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f5f9;
    }

    ::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 3px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #94a3b8;
    }
  </style>
</head>

<body class="bg-slate-100 text-gray-800 font-sans pb-20 lg:pb-0">
  <div class="container mx-auto flex">

    <div id="sidebar-partial-call" class="hidden lg:block">
      <%- include('partials/sidebar') %>
    </div>

    <main class="w-full lg:w-1/2">
      <div>
        <!-- Main Header -->
        <div class="sticky top-0 z-10 flex justify-between items-center bg-slate-100/80 backdrop-blur-md px-4 py-3 border-b border-slate-200">
          <!-- SnapTalk Title (Mobile) / Feeds Title (Desktop) -->
          <h2 class="text-2xl lg:text-3xl font-bold text-gray-900">
            <span class="lg:hidden">SnapTalk</span>
            <span class="hidden lg:inline">Feeds</span>
          </h2>

          <!-- Desktop Links -->
          <div class="hidden lg:flex space-x-4 text-gray-500 font-semibold">
            <a href="#" class="hover:text-gray-900">Recents</a>
            <a href="#" class="text-gray-900 font-bold">Friends</a>
            <a href="#" class="hover:text-gray-900">Popular</a>
          </div>

          <!-- Right Side: Message Icon (Mobile Only) -->
          <a href="#" class="p-2 text-gray-500 hover:text-gray-900 lg:hidden rounded-full hover:bg-slate-200">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </a>
        </div>

        <!-- For You / Following Tabs -->
        <div class="border-b border-slate-200 bg-slate-100/80 backdrop-blur-md">
          <nav id="tab-control" class="flex">
            <button data-target="#for-you-section" class="tab-btn w-1/2 text-center py-4 font-bold text-indigo-600 border-b-2 border-indigo-600 hover:bg-slate-200 transition-colors">For you</button>
            <button data-target="#following-section" class="tab-btn w-1/2 text-center py-4 font-medium text-gray-500 hover:bg-slate-200 transition-colors border-b-0">Following</button>
          </nav>
        </div>


        <div id="feed-story-partial-call" class="block lg:hidden mx-2">
          <%- include("partials/stories") %>
        </div>

        <div id="new-post-partial">
          <%- include('partials/createPost') %>
        </div>

        <div id="for-you-section" class="tab-pane space-y-6 px-2 pb-4">
          <%- include("partials/postTemplate", {posts}) %>
        </div>

        <div id="following-section" class="tab-pane space-y-6 px-2 pb-4">
          <% if(followingUserPosts.length){ %>
          <%- include("partials/postTemplate",{posts:followingUserPosts}) %>
        </div>
        <% }else{ %>
        <span class="flex items-center justify-center mt-[50px] text-[20px] text-gray-500 text-center px-4">
          you will see all people's posts who you are following here.<br>
          currently not following anyone.
        </span>
        <% } %>
    </main>

    <%- include('partials/rightColumn') %>
  </div>

  <%- include('partials/mobileNavigationBar') %>
</body>
<script src="/js/tabs.js"></script>
<script src="/js/feedpage.js"></script>
<script src="/js/createPost.js"></script>
<script src="/js/postEngagements.js"></script>
<script src="/js/followSystem.js"></script>


</html>